<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/MemoFragment">

    <fragment
        android:id="@+id/MemoFragment"
        android:name="com.arcplg.myapplication.MemoFragment"
        android:label="@string/memo_fragment_label"
        tools:layout="@layout/fragment_memo_list">

        <action
            android:id="@+id/action_FirstFragment_to_SecondFragment"
            app:destination="@id/AddMemoFragment" />
    </fragment>
    <fragment
        android:id="@+id/AddMemoFragment"
        android:name="com.arcplg.myapplication.AddMemoFragment"
        android:label="@string/add_memo_fragment_label"
        tools:layout="@layout/fragment_add_memo">

        <action
            android:id="@+id/action_SecondFragment_to_FirstFragment"
            app:destination="@id/MemoFragment" />
    </fragment>
</navigation>